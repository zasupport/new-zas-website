    { "source": "/iphone", "destination": "/iphone-repair", "permanent": true },
    { "source": "/contact-apple-store-johannesburg-near-me", "destination": "/contact", "permanent": true },
    { "source": "/apple-shop/apple-repairs-johannesburg/:slug*", "destination": "/blog", "permanent": true },
    { "source": "/basket", "destination": "/contact", "permanent": true },
    { "source": "/wp-admin", "destination": "/", "permanent": true },
    { "source": "/wp-login.php", "destination": "/", "permanent": true },
    { "source": "/apple-repair/logic-board", "destination": "/logic-board-repair", "permanent": true },
    { "source": "/apple-repair/battery", "destination": "/macbook-repair/battery", "permanent": true },
