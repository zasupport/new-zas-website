{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/seo-report/cron", "schedule": "0 7 * * *" }
  ],
  "redirects": [
    { "source": "/services/mac-repair", "destination": "/apple-repair", "permanent": true },
    { "source": "/services/liquid-damage", "destination": "/liquid-damage", "permanent": true },
    { "source": "/services/jamf", "destination": "/jamf-mdm", "permanent": true },
    { "source": "/services/iphone-repair", "destination": "/iphone-repair", "permanent": true },
    { "source": "/services/ipad-repair", "destination": "/ipad-repair", "permanent": true },
    { "source": "/services/logic-board", "destination": "/logic-board-repair", "permanent": true },
    { "source": "/repair", "destination": "/apple-repair", "permanent": true },
    { "source": "/contact-us", "destination": "/contact", "permanent": true },
    { "source": "/apple-support-johannesburg", "destination": "/apple-support", "permanent": true },
    { "source": "/managed-it-services", "destination": "/managed-services", "permanent": true },
    { "source": "/macbook-repairs-near-me-johannesburg", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-battery-replacement-near-me-johannesburg-south-africa", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-screen-repair-sandton-johannesburg-south-africa", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-pro-repair-near-me-sandton-johannesburg", "destination": "/logic-board-repair/macbook-pro", "permanent": true },
    { "source": "/macbook-pro-screen-replacement-near-me-johannesburg-south", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-air-screen-replacement-near-me", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-air-repair-near-me-sandton-johannesburg-south-africa", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-pro-battery-replacement-near-me-johannesburg-south-africa", "destination": "/apple-repair", "permanent": true },
    { "source": "/macbook-air-battery-replacement-near-me", "destination": "/apple-repair", "permanent": true },
