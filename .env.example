# ZA Support Website — Environment Variables
# Copy to .env.local and fill in values

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Email (Resend)
RESEND_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://zasupport.com

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GA4_ID=

# Google APIs
# Enable in Google Cloud Console: Places API (New), Maps JavaScript API,
# Geocoding API, Distance Matrix API, Geolocation API, PageSpeed Insights API
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # Same key as above — exposed to browser for Maps JS embed
GOOGLE_PLACE_ID=                  # ZA Support Google Place ID — find at: maps.google.com → your business → Share → Copy link
PSI_API_KEY=                      # PageSpeed Insights — same Google API key works
