node_modules/
/.next/
/out/
.env
.env.local
.env.*.local
.vercel
*.tsbuildinfo
next-env.d.ts
.DS_Store
npm-debug.log*

# Security: credential documents — never commit files with literal secrets
docs/seo/*PLATFORM*SETUP*.md
docs/seo/*CREDENTIALS*.md
docs/seo/*API*KEYS*.md
*SETUP*GUIDE*.md
*.env.secret
docs/seo/.advisor-gap-inbox.jsonl
docs/seo/advisor-gap-inbox.md

# Python bytecode — tracked .pyc caused an audit tool to score itself WIRED by its own
# bytecode (grep -r descends __pycache__). Never track compiled artefacts.
__pycache__/
*.pyc
